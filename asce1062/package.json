{
  "name": "alex mbugua's website",
  "type": "module",
  "version": "0.0.1",
  "homepage": "https://asce1062.github.io/asce1062",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build --remote",
    "format": "prettier --write . --ignore-path .prettierignore",
    "lint": "eslint . --ext .js,.ts,.astro",
    "lint:fix": "eslint . --ext .js,.ts,.astro --fix",
    "predeploy": "npm run generate:ascii && astro check && COMMIT_REF=$(git rev-parse HEAD) astro build --remote",
    "deploy": "gh-pages -d dist --branch alexmbugua --nojekyll --cname alexmbugua.me --dotfiles",
    "deploy:netlify": "netlify deploy --prod",
    "deploy:netlify:preview": "netlify deploy",
    "preview": "astro preview",
    "preview:netlify": "netlify dev",
    "astro": "astro",
    "check": "astro check",
    "knip": "knip",
    "prepare": "husky || true",
    "generate:ascii": "node scripts/generate-ascii.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/db": "^0.19.0",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/netlify": "^6.6.4",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@pagefind/default-ui": "^1.4.0",
    "@rehype-pretty/transformers": "^0.13.2",
    "@stefanprobst/remark-extract-toc": "^2.2.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "^5.18.0",
    "astro-og-canvas": "^0.10.1",
    "astro-pagefind": "^1.8.5",
    "astro-themes": "^0.2.7",
    "autoprefixer": "^10.4.27",
    "lightningcss": "^1.31.1",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.4.0",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.8",
    "postcss-nesting": "^14.0.0",
    "reading-time": "^1.5.0",
    "rehype-accessible-emojis": "^0.3.2",
    "rehype-external-links": "^3.0.0",
    "rehype-pretty-code": "^0.14.1",
    "remark-slug": "^7.0.1",
    "shiki": "^3.23.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.6",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@types/papaparse": "^5.5.2",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "figlet": "^1.11.0",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.2",
    "netlify-cli": "^24.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-toml": "^2.0.6"
  },
  "lint-staged": {
    "*.{js,ts,mjs,astro}": [
      "eslint --fix",
      "prettier --write --ignore-path .prettierignore"
    ],
    "*.{json,md,mdx,css,yml,yaml,toml}": [
      "prettier --write --ignore-path .prettierignore"
    ]
  }
}
