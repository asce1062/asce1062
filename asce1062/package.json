{
  "name": "alex mbugua's website",
  "type": "module",
  "version": "0.0.1",
  "homepage": "https://asce1062.github.io/asce1062",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build --remote",
    "format": "prettier --write . --ignore-path .prettierignore",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "predeploy": "npm run generate:ascii && astro check && COMMIT_REF=$(git rev-parse HEAD) astro build --remote",
    "deploy": "gh-pages -d dist --branch alexmbugua --nojekyll --cname alexmbugua.me --dotfiles",
    "deploy:netlify": "netlify deploy --prod",
    "deploy:netlify:preview": "netlify deploy",
    "preview": "astro preview",
    "preview:netlify": "netlify dev",
    "astro": "astro",
    "check": "astro check",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true",
    "hash:admin-token": "node scripts/hash-admin-token.mjs",
    "generate:ascii": "node scripts/generate-ascii.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/db": "^0.21.3",
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/netlify": "^8.1.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@node-rs/argon2": "^2.0.2",
    "@pagefind/default-ui": "^1.5.2",
    "@rehype-pretty/transformers": "^0.13.2",
    "@stefanprobst/rehype-extract-toc": "^3.0.0",
    "@tailwindcss/postcss": "^4.3.3",
    "astro": "^7.1.3",
    "astro-og-canvas": "^0.13.0",
    "astro-pagefind": "^2.0.1",
    "astro-themes": "^0.2.7",
    "autoprefixer": "^10.5.4",
    "lightningcss": "^1.33.0",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.5.2",
    "papaparse": "^5.5.4",
    "postcss": "^8.5.22",
    "postcss-nesting": "^14.0.0",
    "reading-time": "^1.5.0",
    "rehype-accessible-emojis": "^0.3.2",
    "rehype-external-links": "^3.0.0",
    "rehype-pretty-code": "^0.14.4",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.35.3",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.3",
    "typescript": "6.0.3",
    "validator": "^13.15.35",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.10",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/papaparse": "^5.5.2",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "astro-eslint-parser": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "figlet": "^1.11.3",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "knip": "^6.29.0",
    "lint-staged": "^17.1.1",
    "netlify-cli": "^26.2.0",
    "prettier": "^3.9.6",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-toml": "^2.0.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{js,ts,mjs,astro}": [
      "eslint --fix",
      "prettier --write --ignore-path .prettierignore"
    ],
    "*.{json,md,mdx,css,yml,yaml,toml}": [
      "prettier --write --ignore-path .prettierignore"
    ]
  }
}
