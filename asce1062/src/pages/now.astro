---
import Layout from "@/layouts/Layout.astro";
import GitHubContributions from "@/components/GitHubContributions.astro";
---

<Layout title="Now" ogImage="images/social-preview.png" description="What I'm currently focused on">
	<article>
		<!-- prettier-ignore-start -->
		<h2>
			This is a <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">now page</a><sup
				><a href="https://slashpages.net/#now" target="_blank" rel="noopener noreferrer">1</a></sup
			>.
		</h2>
		<!-- prettier-ignore-end -->

		<section class="mb-10">
			<p class="text-xs text-neutral-content mb-2">
				<span class="text-success font-bold">$</span>
				<span class="ml-1 text-warning">ps aux | grep working</span>
				<span class="blink">_</span>
			</p>
			<h2><i class="icon-gear"></i> I'm currently working on</h2>
			<p>
				Federated authentication and secure SSO flows for enterprise platforms, improving scalability and user
				experience across the board. I'm also mentoring engineers and contributing to projects that support millions of
				learners.
			</p>
		</section>

		<section class="mb-10">
			<p class="text-xs text-neutral-content mb-2">
				<span class="text-success font-bold">$</span>
				<span class="ml-1 text-warning">cat ~/learning.log</span>
				<span class="blink">_</span>
			</p>
			<h2><i class="icon-journal-code"></i> I'm currently learning</h2>
			<ul>
				<li>Advanced observability and distributed tracing with Datadog.</li>
				<li>
					Astro framework by building my personal <a
						href="https://alexmbugua.me/"
						target="_blank"
						rel="noopener noreferrer">
						site
					</a>. Fully <a
						href="https://github.com/asce1062/asce1062/tree/main/asce1062"
						target="_blank"
						rel="noopener noreferrer">
						open source
					</a>.
				</li>
			</ul>
		</section>

		<section class="mb-10">
			<p class="text-xs text-neutral-content mb-2">
				<span class="text-success font-bold">$</span>
				<span class="ml-1 text-warning">ls ~/open-to-collab/</span>
				<span class="blink">_</span>
			</p>
			<h2><i class="icon-people"></i> I'm looking to collaborate on</h2>
			<ul>
				<li>Designing multi-tenant SaaS authentication that gracefully supports both B2B and B2C flows.</li>
				<li>Initiatives building resilient infrastructure and serverless architectures.</li>
				<li>Open Source Projects in the authentication, DevTools, or EdTech space.</li>
			</ul>
		</section>

		<section class="mb-10">
			<p class="text-xs text-neutral-content mb-2">
				<span class="text-success font-bold">$</span>
				<span class="ml-1 text-warning">man alex</span>
				<span class="blink">_</span>
			</p>
			<h2><i class="icon-chat-square-dots"></i> Ask me about</h2>
			<p>
				Content management with Hygraph(graphQL), Auth0, SSO flows, SAML, OAuth, Terraform, serverless patterns on AWS,
				building progressive profiling flows, or streamlining engineering workflows.
			</p>
		</section>

		<section class="mb-10">
			<p class="text-xs text-neutral-content mb-2">
				<span class="text-success font-bold">$</span>
				<span class="ml-1 text-warning">cat ~/fun.txt</span>
				<span class="blink">_</span>
			</p>
			<h2><i class="icon-lightning-charge"></i> Fun fact</h2>
			<p>
				When I'm not contributing to open source projects or reverse engineering things for fun, I <a
					href="https://asce1062.github.io/"
					target="_blank"
					rel="noopener noreferrer">
					compose chip music
				</a>.
			</p>
		</section>

		<section class="mb-10">
			<p class="text-xs text-neutral-content mb-2">
				<span class="text-success font-bold">$</span>
				<span class="ml-1 text-warning">gh contributions --user asce1062</span>
				<span class="blink">_</span>
			</p>
			<h2><i class="icon-github"></i> Contributions</h2>
			<GitHubContributions username="asce1062" />
		</section>

		<hr class="my-8 border-base-300" />

		<section class="mb-6">
			<p class="text-xs text-neutral-content mb-2">
				<span class="text-error font-bold">$</span>
				<span class="ml-1 text-warning">exit</span>
				<span class="blink">_</span>
			</p>
			<blockquote>
				<p>
					<em>
						P.S. I'm open to exciting new opportunities, especially roles where authentication, infrastructure, or
						education outcomes intersect with impact-driven engineering...
					</em><i class="icon-rocket-takeoff"></i>
				</p>
			</blockquote>
			<p>
				<small class="italic">
					This page was last updated in March 2026. Learn more about <a
						href="https://nownownow.com/about"
						target="_blank"
						rel="noopener noreferrer">
						now pages
					</a>.
				</small>
			</p>
			<div class="flex flex-wrap gap-3 mt-4">
				<a href="/about" class="link-action no-underline">
					<i class="icon-person"></i>
					About
				</a>
				<a href="/interests" class="link-action no-underline">
					<i class="icon-collection"></i>
					Interests
				</a>
				<a href="/hello" class="link-action no-underline">
					<i class="icon-chat-square-heart"></i>
					Hello
				</a>
				<a href="/blog" class="link-action no-underline">
					<i class="icon-journal-richtext"></i>
					Blog
				</a>
			</div>
		</section>
	</article>
</Layout>
