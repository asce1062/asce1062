---
import Layout from "@/layouts/Layout.astro";
import SearchBox from "@/components/SearchBox.astro";
---

<Layout
	title="Search"
	ogImage="images/social-preview.png"
	description="Find articles, topics and ideas by Alex Mbugua"
	ogImage="images/social-preview.png">
	<section id="pagefind-search">
		<h1>Search</h1>
		<p class="italic text-warning opacity-40">Find articles, topics and ideas...</p>
		<SearchBox searchId="page-searchbox" showTips={true} />
	</section>
</Layout>

<script>
	import { initSearchShortcut, initSlashSearchShortcut } from "@/scripts/keyboardShortcuts";

	type SearchShortcutWindow = Window &
		typeof globalThis & {
			__searchPageShortcutCleanup?: () => void;
			__searchPageSlashShortcutCleanup?: () => void;
		};

	const searchWindow = window as SearchShortcutWindow;
	searchWindow.__searchPageShortcutCleanup?.();
	searchWindow.__searchPageSlashShortcutCleanup?.();

	searchWindow.__searchPageShortcutCleanup = initSearchShortcut();
	searchWindow.__searchPageSlashShortcutCleanup = initSlashSearchShortcut(() => {
		const input = document.querySelector(".pagefind-ui__search-input") as HTMLInputElement | null;
		input?.focus();
	});
</script>
