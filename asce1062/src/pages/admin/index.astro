---
/**
 * Admin hub page
 * Login form sets a cookie for token-based auth, which is checked on all /admin/* pages
 * Lists all auth-protected pages on the site
 */
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import { countPendingEntries } from "@/lib/api/guestbook";
import { getAdminCookieToken, isValidToken, setAdminCookie, deleteAdminCookie } from "@/lib/api/admin-auth";

const ADMIN_PAGES = [
	{
		title: "Guestbook Moderation",
		href: "/admin/guestbook",
		description: "Review, approve, or hide pending and flagged entries.",
		icon: "icon-journal-bookmark",
	},
];
// Auth: check cookie
const isAuthed = isValidToken(getAdminCookieToken(Astro.cookies));

// Handle POST actions
let loginError = false;

if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	const action = String(formData.get("action") ?? "");

	if (action === "login") {
		const submittedToken = String(formData.get("token") ?? "");
		if (isValidToken(submittedToken)) {
			setAdminCookie(Astro.cookies, submittedToken);
			return Astro.redirect("/admin");
		}
		// Slow down sequential brute-force attempts.
		// Note:
		// 	- on serverless each invocation is isolated
		// 	- this only throttles single-threaded attacks
		await new Promise((r) => setTimeout(r, 500));
		loginError = true;
	}

	if (action === "logout") {
		deleteAdminCookie(Astro.cookies);
		return Astro.redirect("/admin");
	}
}

const pendingCount = isAuthed ? await countPendingEntries() : 0;
---

<Layout title="Admin" description="Admin hub">
	{
		isAuthed ? (
			<>
				<div class="flex items-center justify-between mb-6 gap-4">
					<h2>Admin</h2>
					<form method="POST">
						<input type="hidden" name="action" value="logout" />
						<button type="submit" class="btn btn-error btn-sm">
							Logout
						</button>
					</form>
				</div>

				<div class="space-y-4">
					{ADMIN_PAGES.map((page) => (
						<div class="bg-base-200/60 border border-base-300 p-4 rounded">
							<div class="flex items-start justify-between gap-4">
								<div>
									<i class={page.icon} />
									<a href={page.href} class="font-semibold transition-colors">
										{page.title}
									</a>
									<p class="text-sm text-base-content/60 mt-1 mb-0">{page.description}</p>
								</div>
								<span class={`badge badge-sm shrink-0 mt-0.5 ${pendingCount > 0 ? "badge-info" : "badge-neutral"}`}>
									{pendingCount} pending
								</span>
							</div>
						</div>
					))}
				</div>
			</>
		) : (
			<div class="min-h-[40vh] flex items-center justify-center">
				<div class="w-full max-w-sm p-8 bg-neutral/20 border border-primary">
					<h1 class="font-retro text-2xl text-center mb-6 tracking-widest">[ admin ]</h1>
					<form method="POST" data-astro-reload class="space-y-4">
						<input type="hidden" name="action" value="login" />
						<div class="space-y-1">
							<input
								type="password"
								name="token"
								placeholder="token"
								autocomplete="current-password"
								class="input input-accent w-full"
								autofocus
							/>
							{loginError && <p class="-mt-1 text-error text-sm">Invalid token.</p>}
						</div>
						<button type="submit" class="btn btn-secondary w-full">
							Login
						</button>
					</form>
				</div>
			</div>
		)
	}
</Layout>
