---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import PreviewImage from "@/components/PreviewImage.astro";
import PrivacyPolicy from "@/components/PrivacyPolicy.astro";
import GuestbookEntry from "@/components/GuestbookEntry.astro";
import ShareNotification from "@/components/ShareNotification.astro";
import Expand from "@/components/ui/Expand.astro";
import AvatarMiniWidget from "@/components/AvatarMiniWidget.astro";
import {
	getGuestEntries,
	createGuestEntry,
	getNotificationFlags,
	markAdminNotified,
	markCopySent,
} from "@/lib/api/guestbook";
import { notifyNewEntry, sendEntryCopy } from "@/lib/api/guestbook-notify";
import { patterns, swatchColors, radiusValues, borderStyles, toTitleCase } from "@/config/guestbook";
import "@/styles/components/guestbook.css";

const image = "/src/assets/guestbook/guestbook.png";
const title = "Guestbook";
const description = "Drop me a note, let's connect ^^";

if (Astro.request.method === "POST") {
	const formData = await Astro.request.formData();
	const name = formData.get("name") as string;
	const email = formData.get("email") as string;
	const url = formData.get("url") as string;
	const message = formData.get("message") as string;
	const style = formData.get("style") as string;
	const avatarState = formData.get("avatarState") as string | null;
	const avatarOptIn = formData.get("avatarOptIn") === "on";
	const theme = formData.get("theme") === "dark" ? "dark" : "light";
	const sendCopy = formData.get("send-copy") === "on";
	const honeypot = formData.get("bot-field");

	// Extract client IP (Netlify headers → standard fallbacks → dev stub)
	const ip =
		Astro.request.headers.get("x-nf-client-connection-ip") ||
		Astro.request.headers.get("x-forwarded-for")?.split(",")[0]?.trim() ||
		Astro.request.headers.get("client-ip") ||
		(import.meta.env.DEV ? "127.0.0.1" : undefined);

	const userAgent = Astro.request.headers.get("user-agent") || undefined;

	if (
		!honeypot &&
		typeof name === "string" &&
		typeof message === "string" &&
		name.trim().length > 0 &&
		message.trim().length > 0 &&
		message.trim().length <= 2000
	) {
		const { classification, entryId, submittedAt } = await createGuestEntry({
			name,
			email,
			url,
			message,
			style,
			avatarState,
			avatarOptIn,
			ip,
			userAgent,
		});

		// Await notifications before redirecting
		// Fire-and-forget is not safe in serverless
		// Function shuts down after response, cutting off any unawaited async work
		const validEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email ?? "");
		try {
			const flags = await getNotificationFlags(entryId);
			if (!flags.adminNotifiedAt) {
				const result = await notifyNewEntry({
					name,
					email,
					url,
					message,
					style,
					avatarState: avatarOptIn ? avatarState : null,
					classification,
					entryId,
					theme,
					submittedAt,
				});
				if (result.ok) await markAdminNotified(entryId);
			}
			if (sendCopy && validEmail && !flags.copySentAt) {
				// spam/hidden/rate-limited guard is applied inside sendEntryCopy
				const result = await sendEntryCopy({
					name,
					email,
					message,
					style,
					avatarState: avatarOptIn ? avatarState : null,
					classification,
					entryId,
					theme,
					submittedAt,
				});
				if (result.ok) await markCopySent(entryId);
			}
		} catch (err) {
			console.error("[guestbook] Notification error:", err);
		}

		return Astro.redirect("/success");
	}
}

const entries = await getGuestEntries();
---

<Layout title={title} ogImage="images/social-preview.png" description={description}>
	<PreviewImage src={image} altText={title} />
	<h2>{title}</h2>
	<p>{description}</p>
	<p>
		In the spirit of the beautifully chaotic, handcrafted web of yesteryear, when we all had personal homepages filled
		with <span class="blink">blinking text</span>, dubious counters <strong>
			Visitor# <span id="counter">000000</span>
		</strong>, way too many <marquee>marquee tags</marquee> and
		<span class="faded-text">color faded text (not just to impress recruiters)</span>, I've decided to bring back the
		classic guestbook.
	</p>
	<div>
		Just keep in mind:
		<ul>
			<li>Messages appear instantly, no waiting for the next time I ship an update.</li>
			<li>All messages are subject to moderation and may be removed after the fact.</li>
			<li>Be kind. Spam and abuse will be removed.</li>
		</ul>
		<form id="form" method="POST">
			<input type="hidden" name="theme" id="theme-input" value="light" />
			<p>
				<label>
					Name
					<br /><input class="input-allowed" type="text" name="name" required />
				</label>
			</p>
			<p>
				<label>
					Email <small>(optional, not published)</small>
					<br /><input class="input-allowed" type="email" name="email" id="email-input" />
				</label>
			</p>
			<p>
				<label>
					URL <small>(optional, linked from Name)</small>
					<br /><input
						class="input-allowed"
						type="url"
						name="url"
						placeholder="https://example.com"
						pattern="https://.*"
					/>
				</label>
			</p>
			<p>
				<label>
					Subject <small>(please <b>skip</b> this field if you're real)</small>
					<br /><input class="input-honeypot" type="text" name="bot-field" placeholder="Leave me be!" />
					<small>Are you sure you want to type in here? <b>I won't get your message</b>!</small>
				</label>
			</p>
			<p>
				<label class="message" for="message-textarea"> Message </label>
			</p>

			<input type="hidden" id="style-input" name="style" />
			<input type="hidden" id="avatar-state-input" name="avatarState" />

			<div class="mb-4 max-w-[380px]">
				<Expand title="Customize your card" id="customizer-panel">
					<div slot="content" class="p-4">
						<!-- Background Pattern -->
						<div class="customizer-section">
							<h4>Background Pattern</h4>
							<div class="customizer-row">
								<select id="pattern-select" class="input-allowed pattern-select">
									<option value="none">None</option>
									{patterns.map((p) => <option value={p}>{toTitleCase(p)}</option>)}
								</select>
								<div id="pattern-swatch" class="pattern-swatch"></div>
							</div>
						</div>

						<!-- Border Radius -->
						<div class="customizer-section">
							<h4>Border Radius</h4>
							<div class="flex gap-2">
								{
									radiusValues.map((r) => (
										<div
											class="option-card rounded-field bg-base-200 hover:bg-base-300 cursor-pointer overflow-hidden transition-colors"
											data-radius={r}
											title={r}>
											<div class="pe-3 pt-2">
												<div
													class="h-6 w-8 border-e-2 border-t-2 border-base-content/20"
													style={`border-start-end-radius: ${r}`}
												/>
											</div>
										</div>
									))
								}
							</div>
						</div>

						<!-- Border Width -->
						<div class="customizer-section">
							<h4>Border Width</h4>
							<div class="relative mt-6 mb-1">
								<kbd
									id="border-width-label"
									class="kbd kbd-sm absolute bottom-full mb-1 -translate-x-1/2 text-[0.625rem]"
									style="left: calc(14.29% + 0.446rem);">1px</kbd
								>
								<input
									id="border-width-slider"
									type="range"
									min="0"
									max="7"
									step="1"
									value="1"
									class="w-full h-2 rounded-full appearance-none cursor-pointer bg-base-300 range-styled"
								/>
							</div>
						</div>

						<!-- Border Color -->
						<div class="customizer-section">
							<h4>Border Color</h4>
							<div class="customizer-row">
								{
									swatchColors.map((c) => (
										<div class="color-swatch" data-border-color={c} style={`background-color: var(--color-${c})`} />
									))
								}
							</div>
						</div>

						<!-- Border Style -->
						<div class="customizer-section">
							<h4>Border Style</h4>
							<div class="flex gap-2">
								{
									borderStyles.map((s) => (
										<div
											class="option-card rounded-field bg-base-200 hover:bg-base-300 cursor-pointer overflow-hidden transition-colors"
											data-border-style={s}
											title={s}>
											<div class="pe-3 pt-2">
												{s === "none" ? (
													<div class="h-6 w-8 flex items-center justify-center text-base-content/40">
														<i class="icon-x-lg -mt-1 -ml-1" />
													</div>
												) : (
													<div
														class="h-6 w-8 border-e-2 border-t-2 border-base-content/20"
														style={`border-style: ${s}; border-start-end-radius: 0.25rem${s === "double" ? "; border-block-start-width: 4px; border-inline-end-width: 4px" : ""}`}
													/>
												)}
											</div>
										</div>
									))
								}
							</div>
						</div>

						<!-- 8-bit Avatar -->
						<div class="customizer-section">
							<h4>8-bit Avatar</h4>
							<AvatarMiniWidget instanceId="guestbook" canvasClass="guestbook-avatar-canvas avatar-frame" />
							<label class="consent">
								<input type="checkbox" id="avatar-opt-in" name="avatarOptIn" class="checkbox checkbox-xs" />
								<small>Include avatar in this entry</small>
							</label>
							<p id="avatar-random-notice" class="avatar-random-notice" style="display:none">
								<small><i class="icon-info-circle"></i> No avatar customized. A random one will be generated.</small>
							</p>
						</div>

						<div class="flex justify-end mb-4">
							<button type="button" id="customizer-done" class="btn btn-neutral">
								<i class="font-retro">Done</i>
							</button>
						</div>
					</div>
				</Expand>
			</div>

			<div class="mb-4">
				<button
					type="button"
					id="customizer-random"
					class="h-7 w-7 md:h-8 md:w-8 rounded-md transition-all duration-100 hover:text-accent hover:rotate-6 cursor-pointer">
					<i class="icon-magic text-lg"></i>
				</button>
			</div>

			<div id="textarea-wrapper" class="textarea-wrapper">
				<!-- prettier-ignore-start -->
				<textarea
					id="message-textarea"
					name="message"
					rows="4"
					required
					maxlength="2000"
					class="block p-2.5 w-full text-sm textarea-styled"
					placeholder="Say hi, write a poem, or sketch some ASCII art..."></textarea>
				<!-- prettier-ignore-end -->
			</div>

			<p>
				<label class="consent">
					<input type="checkbox" class="checkbox" required /><small>
						I consent to this message being stored in a self-hosted database with honeypot and pattern-based spam
						filtering.
					</small>
				</label>
			</p>
			<p id="send-copy-row" style="display:none">
				<label class="consent">
					<input type="checkbox" class="checkbox" name="send-copy" id="send-copy-checkbox" /><small>
						Receive a copy of this entry @ <span class="badge badge-info" id="send-copy-email"></span></small
					>
				</label>
			</p>
			<p>
				<button type="submit" class="btn btn-success"
					><span class="font-retro text-success-content">Sign Guestbook</span>
				</button>
			</p>
		</form>
		<PrivacyPolicy />
		{entries.map((entry) => <GuestbookEntry entry={entry} />)}
	</div>
	<ShareNotification id="entry-action-notification" message="Copied!" />
</Layout>

<script>
	import { initGuestbookCounter } from "@/scripts/guestbookCounter";
	import { initGuestbookCustomizer } from "@/scripts/guestbookCustomizer";
	import { initGuestbookAvatarWidget } from "@/scripts/guestbookAvatarWidget";
	import { initEntryActions } from "@/scripts/guestbookEntryActions";
	import { initShareNotification } from "@/scripts/feedbackManager";
	import "@/scripts/entryAvatarRenderer";

	function initSendCopyToggle() {
		const emailInput = document.getElementById("email-input") as HTMLInputElement | null;
		const sendCopyRow = document.getElementById("send-copy-row");
		const sendCopyCheckbox = document.getElementById("send-copy-checkbox") as HTMLInputElement | null;
		const sendCopyEmail = document.getElementById("send-copy-email");
		if (!emailInput || !sendCopyRow || !sendCopyCheckbox) return;

		function toggle() {
			const hasValidEmail = emailInput!.checkValidity() && emailInput!.value.trim().length > 0;
			sendCopyRow!.style.display = hasValidEmail ? "" : "none";
			if (!hasValidEmail) sendCopyCheckbox!.checked = false;
			if (sendCopyEmail) sendCopyEmail.textContent = hasValidEmail ? emailInput!.value.trim() : "";
		}

		emailInput.addEventListener("input", toggle);
		toggle();
	}

	function initThemeCapture() {
		const form = document.getElementById("form") as HTMLFormElement | null;
		const themeInput = document.getElementById("theme-input") as HTMLInputElement | null;
		if (!form || !themeInput) return;
		form.addEventListener("submit", () => {
			themeInput.value = document.documentElement.dataset.theme ?? "light";
		});
	}

	function initGuestbook() {
		initGuestbookCounter();
		initGuestbookCustomizer();
		initGuestbookAvatarWidget();
		initEntryActions();
		initSendCopyToggle();
		initThemeCapture();
		// Guard: notification element may not exist during view transition navigation
		if (document.getElementById("entry-action-notification")) {
			initShareNotification("entry-action-notification");
		}
	}

	document.addEventListener("astro:page-load", initGuestbook);
</script>
