---
/**
 * Entry copy email HTML template.
 * Email sent to the guest when they opt in to receive a copy of their entry.
 * Rendered server-side via AstroContainer. Never served as a page.
 * Dark/Light theme is baked in at render time from the submitter's active site theme.
 */
import type { ModerationStatus } from "@/lib/api/guestbook";
import { hexLight, hexDark } from "@/config/design-tokens";
import { getPatternDataUri, parseEntryStyle } from "@/lib/email/helpers";
import { SOCIAL } from "@/config/site-config";
import { BASE_URL, GITHUB_ISSUES_URL, MAX_COPY_MSG_CHARS } from "@/config/email-config";

interface Props {
	name: string;
	message: string;
	style?: string; // JSON string, same format stored in DB
	status: ModerationStatus;
	entryId: number;
	theme: "light" | "dark";
}

const { name, message, style: styleJson, status, entryId, theme } = Astro.props;

// Single color palette selected at render time
const C = theme === "dark" ? hexDark : hexLight;

const entryStyle = parseEntryStyle(styleJson);

const borderColor = C[entryStyle.borderColor] ?? C["base-300"];
const borderCss =
	entryStyle.borderStyle === "none"
		? `border:none;border-radius:${entryStyle.borderRadius};`
		: `border:${entryStyle.borderWidth} ${entryStyle.borderStyle} ${borderColor};border-radius:${entryStyle.borderRadius};`;

// Body background. Remote URL.
const bodyPattern = theme === "dark" ? `${BASE_URL}/topography.svg` : `${BASE_URL}/topographylight.svg`;
const bodyBgCss = `background-color:${C["base-100"]};background-image:url("${bodyPattern}");`;

// Card pattern. Inline base64 so it survives clients that block remote images.
// Notecard SVGs are small (<5 KB) and don't push email past most email clients' 102 KB clip limit.
const patternFill = theme === "dark" ? hexDark["base-300"] : hexLight["base-300"];
const patternDataUri = getPatternDataUri(entryStyle.bg, patternFill);
const cardBgCss = patternDataUri
	? `background-color:${C["base-200"]};background-image:url("${patternDataUri}");background-size:60px;background-repeat:repeat;`
	: `background-color:${C["base-200"]};`;

const entryUrl = `${BASE_URL}/guestbook#entry-${entryId}`;

// Truncate before render. Server-side safety net for clients that don't support max-height/overflow-y
const previewMsg = message.length > MAX_COPY_MSG_CHARS ? message.slice(0, MAX_COPY_MSG_CHARS) + "…" : message;
const truncated = message.length > MAX_COPY_MSG_CHARS;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1.0" />
		<meta name="x-apple-disable-message-reformatting" />
	</head>
	<body style={`margin:0;padding:0;${bodyBgCss}font-family:'Courier New',Courier,monospace;`}>
		<!-- Preheader: inbox preview text. Hidden visually in all email clients -->
		<div
			style="display:none;font-size:1px;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;mso-hide:all;">
			Here's a copy of your guestbook entry - {previewMsg.slice(0, 90)}
		</div>
		<table
			role="presentation"
			width="100%"
			cellpadding="0"
			cellspacing="0"
			border="0"
			style={`${bodyBgCss}padding:24px 0;`}>
			<tr>
				<td align="center">
					<table
						role="presentation"
						width="600"
						cellpadding="0"
						cellspacing="0"
						border="0"
						style="max-width:600px;width:100%;">
						<!-- Greeting -->
						<tr>
							<td style="padding:0 0 20px;text-align:center;">
								<p style={`margin:0;font-size:20px;color:${C["base-content"]};font-weight:bold;`}>
									&#128214; alexmbugua.me
								</p>
								<p style={`margin:6px 0 0;font-size:13px;color:${C["neutral-content"]};`}>
									Hi {name}, here&rsquo;s a copy of your guestbook entry
								</p>
								<p style={`margin:4px 0 0;font-size:11px;color:${C["neutral-content"]};`}>
									You opted in to receive this when you submitted your entry.
								</p>
							</td>
						</tr>

						<tr>
							<td>
								<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
									<tr>
										<td style={`${borderCss}${cardBgCss}padding:16px;`}>
											<!--
												max-height + overflow-y:auto for clients that support it.
												Server-side truncation at MAX_COPY_MSG_CHARS is the safety net for clients that don't.
											-->
											<pre
												style={`margin:0;padding:0;font-family:'Courier New',Courier,monospace;font-size:14px;font-weight:400;color:${C["base-content"]};white-space:pre-wrap;word-break:break-word;line-height:1.6;max-height:320px;overflow-y:auto;background:transparent;border:none;`}
												>{previewMsg}{truncated && <span style={`color:${C["neutral-content"]};font-style:italic;`}> … (truncated)</span>}</pre
											>
										</td>
									</tr>
								</table>
							</td>
						</tr>

						<!-- Action row: view link (visible only), pending review notice (pending) -->
						{
							status === "visible" && (
								<tr>
									<td style="padding-top:20px;text-align:center;">
										<table cellpadding="0" cellspacing="0" border="0" role="presentation" style="margin:0 auto;">
											<tr>
												<td style={`background:${C["success"]};`}>
													<a
														href={entryUrl}
														style={`display:block;padding:8px 20px;font-size:13px;text-decoration:none;font-family:'Courier New',Courier,monospace;font-weight:bold;color:${C["success-content"]};`}>
														View on guestbook &rarr;
													</a>
												</td>
											</tr>
										</table>
									</td>
								</tr>
							)
						}
						{
							status === "pending" && (
								<Fragment>
									<tr>
										<td style="padding-top:14px;">
											<p
												style={`margin:0;font-size:12px;color:${C["warning"]};font-family:'Courier New',Courier,monospace;`}>
												&#9888;&#65039; Your entry is pending review. It will appear on the guestbook once approved.
											</p>
										</td>
									</tr>
									<tr>
										<td
											style={`padding-top:14px;text-align:center;font-size:12px;color:${C["neutral-content"]};font-family:'Courier New',Courier,monospace;`}>
											Questions? Get in touch:&nbsp;
											<a href={`mailto:${SOCIAL.email}`} style={`color:${C["accent"]};text-decoration:none;`}>
												{SOCIAL.email}
											</a>
											&nbsp;or&nbsp;
											<a href={GITHUB_ISSUES_URL} style={`color:${C["accent"]};text-decoration:none;`}>
												open a GitHub issue
											</a>
											.
										</td>
									</tr>
								</Fragment>
							)
						}

						<!-- Footer -->
						<tr>
							<td style={`padding:24px 0 0;text-align:center;font-size:11px;color:${C["neutral-content"]};`}>
								<a href={`${BASE_URL}/guestbook`} style={`color:${C["neutral-content"]};text-decoration:none;`}>
									alexmbugua.me/guestbook
								</a>
							</td>
						</tr>
					</table>
				</td>
			</tr>
		</table>
	</body>
</html>
