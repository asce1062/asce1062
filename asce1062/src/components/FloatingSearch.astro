---
/**
 * Floating Search Modal
 * A modal overlay for search that can be triggered from anywhere on the site
 * Uses a separate pagefind instance to avoid conflicts with the main search page
 */
import SearchBox from "@/components/SearchBox.astro";

const currentPath = Astro.url.pathname;
const isSearchPage = currentPath === "/search" || currentPath === "/search/";
---

{
	!isSearchPage && (
		<>
			<div
				id="floating-search-overlay"
				class="fixed inset-0 bg-[color-mix(in_oklab,var(--color-base-100)_70%,transparent)] z-100 opacity-0 pointer-events-none transition-opacity duration-300"
				aria-hidden="true"
			/>
			<div
				id="floating-search-modal"
				class="fixed left-0 right-0 lg:left-[var(--sidebar-current-width)] mx-auto w-[calc(100%-2rem)] md:w-[calc(100%-4rem)] lg:w-[calc(50%-4rem)] max-h-[calc(100vh-8rem)] overflow-y-auto p-5 z-101 bg-base-100 border border-base-300 opacity-0 pointer-events-none transition-opacity duration-300"
				role="dialog"
				aria-modal="true"
				aria-labelledby="floating-search-title">
				<div class="flex items-center justify-between mb-4">
					<h2 id="floating-search-title" class="m-0 leading-none">
						<a href="/search">Search</a>
					</h2>
					<button id="close-floating-search" class="btn btn-frame btn-error btn-sm" aria-label="Close search">
						<i class="icon-x-lg" />
					</button>
				</div>
				<div id="pagefind-search-floating">
					<SearchBox searchId="floating-searchbox" showTips={true} />
				</div>
			</div>
		</>
	)
}

<script>
	import { initSearchShortcut, initSlashSearchShortcut } from "@/scripts/keyboardShortcuts";

	// AbortController prevents event listeners from accumulating across
	// Astro soft navigations. document/window persist across navigations
	// so without cleanup each astro:page-load adds another set of listeners.
	let _ac: AbortController | null = null;
	let _ro: ResizeObserver | null = null;
	let _shortcutCleanup: (() => void) | null = null;
	let _slashShortcutCleanup: (() => void) | null = null;

	function initFloatingSearch() {
		// Tear down previous listeners and observer before re-init
		_ac?.abort();
		_ro?.disconnect();
		_shortcutCleanup?.();
		_slashShortcutCleanup?.();
		_ac = new AbortController();
		const { signal } = _ac;

		const overlay = document.getElementById("floating-search-overlay");
		const modal = document.getElementById("floating-search-modal");
		const closeBtn = document.getElementById("close-floating-search");
		const openBtn = document.getElementById("open-floating-search");

		if (!overlay || !modal || !closeBtn) return;

		// Track the element that triggered open so we can restore focus on close
		let _opener: HTMLElement | null = null;

		// Position and size modal responsively
		function positionModal() {
			if (!modal) return;
			const firstHr = document.querySelector("header hr");

			if (firstHr) {
				const hrRect = firstHr.getBoundingClientRect();
				const scrollTop = window.scrollY || document.documentElement.scrollTop;
				const topPosition = hrRect.top + scrollTop;
				modal.style.top = `${topPosition}px`;

				// Calculate max-height to ensure modal doesn't overflow viewport
				const viewportHeight = window.innerHeight;
				const bottomPadding = 16; // 1rem in pixels
				const maxHeight = viewportHeight - hrRect.top - bottomPadding;
				modal.style.maxHeight = `${maxHeight}px`;
			}
		}

		// Debounced position update for resize events
		let resizeTimeout: ReturnType<typeof setTimeout>;
		function handleResize() {
			clearTimeout(resizeTimeout);
			resizeTimeout = setTimeout(positionModal, 10);
		}

		// Set initial position with a slight delay to ensure layout is ready
		requestAnimationFrame(positionModal);

		// Update position on various events for responsive behavior
		window.addEventListener("resize", handleResize, { signal });
		window.addEventListener("scroll", positionModal, { signal });
		window.addEventListener("orientationchange", positionModal, { signal });

		// Use ResizeObserver for more responsive updates
		if (typeof ResizeObserver !== "undefined") {
			_ro = new ResizeObserver(() => requestAnimationFrame(positionModal));
			const header = document.querySelector("header");
			if (header) _ro.observe(header);
		}

		// Open floating search
		function openSearch(trigger?: HTMLElement) {
			if (!overlay || !modal) return;
			_opener = trigger ?? (document.activeElement as HTMLElement | null);
			overlay.classList.remove("opacity-0", "pointer-events-none");
			modal.classList.remove("opacity-0", "pointer-events-none");
			document.body.style.overflow = "hidden";

			// Focus on search input after opacity transition starts
			requestAnimationFrame(() => {
				const searchInput = modal?.querySelector('input[type="text"]') as HTMLInputElement | null;
				searchInput?.focus();
			});
		}

		// Close floating search (restore focus to the element that opened it)
		function closeSearch() {
			if (!overlay || !modal) return;
			overlay.classList.add("opacity-0", "pointer-events-none");
			modal.classList.add("opacity-0", "pointer-events-none");
			document.body.style.overflow = "";
			_opener?.focus();
			_opener = null;
		}

		// Event listeners (all tied to signal for automatic cleanup)
		if (openBtn) {
			openBtn.addEventListener("click", () => openSearch(openBtn), { signal });
		}
		closeBtn.addEventListener("click", closeSearch, { signal });
		overlay.addEventListener("click", closeSearch, { signal });

		// Close on Escape key
		document.addEventListener(
			"keydown",
			(e) => {
				if (!e.key) return;
				if (e.key === "Escape" && !modal.classList.contains("pointer-events-none")) {
					closeSearch();
				}
			},
			{ signal }
		);

		// Register Ctrl+K / Cmd+K shortcut to open the floating search
		// Only register if we're NOT on the search page (since openBtn won't exist on search page)
		if (openBtn) {
			_shortcutCleanup = initSearchShortcut('#floating-searchbox input[type="text"]');
			_slashShortcutCleanup = initSlashSearchShortcut(() => {
				if (modal.classList.contains("pointer-events-none")) {
					openSearch();
					return;
				}

				const searchInput = modal.querySelector('input[type="text"]') as HTMLInputElement | null;
				searchInput?.focus();
			});
			// Also open modal when shortcut is pressed (if modal is closed)
			document.addEventListener(
				"keydown",
				(e) => {
					if (!e.key) return;
					const isCtrlOrCmd = e.ctrlKey || e.metaKey;
					if (e.key.toLowerCase() === "k" && isCtrlOrCmd && modal.classList.contains("pointer-events-none")) {
						e.preventDefault();
						openSearch();
					}
				},
				{ signal }
			);
		}
	}

	// Initialize on load
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initFloatingSearch);
	} else {
		initFloatingSearch();
	}

	// Reinitialize after view transitions
	document.addEventListener("astro:page-load", initFloatingSearch);
</script>
