---
/**
 * Header Component
 *
 * Top bar with breadcrumb navigation, theme switcher, search button, and site h1.
 * Navigation is now in the Sidebar component.
 */
import ThemeSwitcher from "@/components/ThemeSwitcher.astro";
import { siteMetadata } from "@/data/navigation";

const url = new URL(Astro.url.pathname, Astro.site);
const link = url.pathname.split("/").filter((i) => i);
const currentPath = Astro.url.pathname;
const isSearchPage = currentPath === "/search" || currentPath === "/search/";
---

<header>
	<div id="navigation" class="mb-4">
		<label for="nav-toggle" class="nav-hamburger" aria-label="Toggle navigation">
			<i class="icon-list hover:-rotate-6" aria-hidden="true"></i>
		</label>
		<div class="float-right flex flex-col gap-2 -mt-2">
			<ThemeSwitcher default="dark" />
			{
				!isSearchPage && (
					<button
						id="open-floating-search"
						type="button"
						class="float-right h-11 w-11 transition-[color,transform] duration-100 hover:text-accent hover:rotate-6 cursor-pointer flex items-center justify-center"
						aria-label="Open search">
						<i class="icon-search-heart" aria-hidden="true" />
					</button>
				)
			}
		</div>

		<b>
			<span class="italic">
				<button
					type="button"
					class="terminal-header-trigger group inline-flex items-center gap-2 rounded-full border border-transparent bg-transparent px-1 py-0.5 text-inherit transition-[color,transform,border-color] duration-150 hover:-translate-y-px hover:text-secondary focus-visible:border-secondary focus-visible:text-secondary focus-visible:outline-none"
					data-navbrand-terminal-trigger
					data-navbrand-terminal-source="header-command-palette"
					aria-label="Open terminal">
					<i class="icon-command-palette inline-block translate-y-1 text-xl -skew-x-12" aria-hidden="true"></i>
					<span class="terminal-header-trigger__nudge md:hidden" aria-hidden="true">&gt;_</span>
				</button>
				<span class="group">
					<a class="no-underline group-hover:bg-primary group-hover:text-primary-content transition-colors" href="/">
						&#x24;HOME
					</a> / <a
						class="no-underline group-hover:bg-primary group-hover:text-primary-content transition-colors"
						href="/">
						asce1062
					</a>
				</span>
				{
					link && link.length > 0 ? (
						<span>
							{link.map((data, index) => (
								<span>
									{" / "}
									<a class="inline! no-underline" href={`/${link.slice(0, index + 1).join("/")}`}>
										{data}
									</a>
									{index === link.length - 1 && (
										<span class="blink -ml-2" aria-hidden="true">
											_
										</span>
									)}
								</span>
							))}
						</span>
					) : (
						<span class="blink -ml-2" aria-hidden="true">
							_
						</span>
					)
				}
			</span>
		</b>
	</div>
	<p
		class="site-greeting"
		data-text-effect="decrypt"
		data-text-effect-triggers="load, hover, tap, click, random-effect, random-time"
		data-text-effect-interval-ms="18000">{siteMetadata.greeting}</p
	>
	<hr class="w-full h-[1.875px] my-4 border-0 bg-base-300" />

	<script>
		import "@/scripts/textEffectRegistry";
	</script>

	<style>
		/* Shared terminal entry in the header. Mobile keeps a visible `>_` nudge;
		desktop uses hover/focus to reveal the same prompt without adding another
		permanent chip beside the breadcrumb line. */
		.terminal-header-trigger__nudge {
			border: 1px solid color-mix(in oklab, var(--color-secondary) 32%, transparent);
			border-radius: 999px;
			padding: 0.08rem 0.32rem;
			font-size: 0.62rem;
			letter-spacing: 0.04em;
			color: color-mix(in oklab, var(--color-secondary) 78%, var(--color-base-content));
			background: color-mix(in oklab, var(--color-base-100) 90%, transparent);
			box-shadow: 0 0 0.8rem color-mix(in oklab, var(--color-secondary) 12%, transparent);
		}

		@media (min-width: 768px) {
			.terminal-header-trigger__nudge {
				opacity: 0;
				transform: translateX(-0.18rem);
				transition:
					opacity 0.2s ease,
					transform 0.2s ease;
			}

			.terminal-header-trigger:hover .terminal-header-trigger__nudge,
			.terminal-header-trigger:focus-visible .terminal-header-trigger__nudge {
				opacity: 1;
				transform: translateX(0);
			}
		}
	</style>
</header>
