---
/**
 * Header Component
 *
 * Top bar with breadcrumb navigation, theme switcher, search button, and site h1.
 * Navigation is now in the Sidebar component.
 */
import ThemeSwitcher from "@/components/ThemeSwitcher.astro";
import { siteMetadata } from "@/data/navigation";

const url = new URL(Astro.url.pathname, Astro.site);
const link = url.pathname.split("/").filter((i) => i);
const currentPath = Astro.url.pathname;
const isSearchPage = currentPath === "/search" || currentPath === "/search/";
---

<header>
	<div id="navigation" class="mb-4">
		<label for="nav-toggle" class="nav-hamburger" aria-label="Toggle navigation">
			<i class="icon-list hover:-rotate-6" aria-hidden="true"></i>
		</label>
		<div class="float-right flex flex-col gap-2 -mt-2">
			<ThemeSwitcher default="dark" />
			{
				!isSearchPage && (
					<button
						id="open-floating-search"
						type="button"
						class="float-right h-11 w-11 transition-[color,transform] duration-100 hover:text-accent hover:rotate-6 cursor-pointer flex items-center justify-center"
						aria-label="Open search">
						<i class="icon-search-heart" aria-hidden="true" />
					</button>
				)
			}
		</div>

		<b>
			<span class="italic">
				<i class="icon-command-palette inline-block translate-y-1 text-xl -skew-x-12" aria-hidden="true"></i>
				<span class="group">
					<a class="no-underline group-hover:bg-primary group-hover:text-primary-content transition-colors" href="/">
						&#x24;HOME
					</a> / <a
						class="no-underline group-hover:bg-primary group-hover:text-primary-content transition-colors"
						href="/">
						asce1062
					</a>
				</span>
				{
					link && link.length > 0 ? (
						<span>
							{link.map((data, index) => (
								<span>
									{" / "}
									<a class="inline! no-underline" href={`/${link.slice(0, index + 1).join("/")}`}>
										{data}
									</a>
									{index === link.length - 1 && (
										<span class="blink -ml-2" aria-hidden="true">
											_
										</span>
									)}
								</span>
							))}
						</span>
					) : (
						<span class="blink -ml-2" aria-hidden="true">
							_
						</span>
					)
				}
			</span>
		</b>
	</div>
	<p class="site-greeting">{siteMetadata.greeting}</p>
	<hr class="w-full h-[1.875px] my-4 border-0 bg-base-300" />

	<script>
		import "@/scripts/greetingReveal";
	</script>
</header>
