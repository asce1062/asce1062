---
/**
 * Sidebar Component
 *
 * CSS checkbox-driven nav drawer.
 *
 * #nav-toggle checkbox (hidden) is the state machine.
 * body:has(#nav-toggle:checked) in sidebar.css handles panel/overlay/hamburger.
 * The hamburger label lives in Header.astro (for="nav-toggle").
 * JS handles: Escape key, scroll lock, close-on-click, header offset.
 */
import "@/styles/components/sidebar.css";
import { mainNavigation, navSections, sidebarOptions } from "@/data/navigation";
import asciiData from "@/data/ascii-art.json";
import AsciiWidget from "@/components/AsciiWidget.astro";
import AvatarMiniWidget from "@/components/AvatarMiniWidget.astro";

const currentPath = Astro.url.pathname;

function isActive(linkHref: string): boolean {
	if (linkHref === "/" && currentPath === "/") return true;
	if (linkHref !== "/" && currentPath.startsWith(linkHref)) return true;
	return false;
}

const grouped = navSections.map((s) => ({
	label: s.label,
	items: mainNavigation.filter((link) => link.section === s.key),
}));

type AsciiVariant = { text: string; font: string; art: string };
const eggVariantsJson = JSON.stringify((asciiData as AsciiVariant[]).filter((v) => v.text !== "404"));
---

<!-- State machine: hidden checkbox -->
<input type="checkbox" id="nav-toggle" class="nav-toggle-input" autocomplete="off" />

<!-- Nav panel -->
<aside
	role="navigation"
	aria-label="Main navigation"
	class="nav-menu fixed top-0 left-0 z-40 flex flex-col w-[var(--sidebar-width)] h-full -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out bg-base-100 bg-[url('/images/topographylight.svg')] dark:bg-[url('/images/topography.svg')]">
	<div class="nav-brand">
		<!-- prettier-ignore -->
		<span class="nav-brand-prompt"><span id="nav-brand-name" class="badge badge-primary badge-sm">alex</span><span class="badge badge-secondary badge-sm">@alexmbugua.me</span><span class="badge badge-accent badge-sm">:~$</span></span>
	</div>

	<nav class="nav-body" aria-label="Main navigation">
		{
			grouped.map(({ label, items }) =>
				items.length > 0 ? (
					<div class="nav-section">
						<div class="nav-section-label">
							<span class="badge badge-secondary badge-sm">&#x276F;</span>
							<span class="badge badge-success badge-sm">{label}</span>
						</div>
						<ul class="nav-list" role="list">
							{items.map((link) => {
								const active = isActive(link.href);
								return (
									<li>
										<b>
											<a
												class:list={["nav-link", { "nav-link--active": active }]}
												href={link.href}
												aria-label={link.ariaLabel}
												aria-current={active ? "page" : undefined}
												{...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}>
												{link.multiPathIcon && link.pathCount ? (
													<span class={`${link.icon} nav-icon`} aria-hidden="true">
														{Array.from({ length: link.pathCount }, (_, i) => (
															<span class={`path${i + 1}`} />
														))}
													</span>
												) : (
													<i class={`${link.icon} nav-icon`} aria-hidden="true" />
												)}
												<span class="nav-text">{link.name}</span>
											</a>
										</b>
									</li>
								);
							})}
						</ul>
					</div>
				) : null
			)
		}

		<!-- Options section: user-controlled site preferences -->
		{
			sidebarOptions.length > 0 && (
				<div class="nav-section">
					<div class="nav-section-label">
						<span class="badge badge-secondary badge-sm">&#x276F;</span>
						<span class="badge badge-success badge-sm">Options</span>
					</div>
					<div class="nav-options-list">
						{sidebarOptions.map((option) => (
							<div class="nav-option">
								<div class="nav-option-control">
									<div class="nav-option-label-group">
										<i class={`${option.icon} nav-icon`} aria-hidden="true" />
										<label class="nav-option-label" for={option.id}>
											{option.label}
										</label>
										<sup
											class="nav-option-info-btn no-underline hover:bg-transparent text-info hover:text-info cursor-default"
											aria-label="More info"
											aria-describedby={`${option.id}-helper`}>
											<i class="icon-info-circle" aria-hidden="true" />
										</sup>
									</div>
									<input
										type="checkbox"
										id={option.id}
										class="toggle toggle-xs"
										aria-describedby={`${option.id}-helper`}
									/>
								</div>
								<p id={`${option.id}-helper`} class="nav-option-helper">
									{option.description}
								</p>
							</div>
						))}
					</div>
				</div>
			)
		}

		<!-- ASCII easter egg. visible on overscroll -->
		<div class="nav-easter-egg" aria-hidden="true">
			<AsciiWidget widgetId="nav-egg" variants={eggVariantsJson} artClass="nav-egg-art" />
		</div>
	</nav>

	<!-- Avatar footer -->
	<div class="nav-status">
		<AvatarMiniWidget instanceId="sidebar" canvasClass="nav-status-avatar avatar-frame" />
	</div>
</aside>

<!-- Overlay transparent click trap. closes nav -->
<label for="nav-toggle" class="nav-overlay" aria-hidden="true"></label>

<script>
	import "@/scripts/sidebarNav";
</script>
<script>
	import "@/scripts/sidebarEgg";
</script>
<script>
	import "@/scripts/sidebarAvatar";
</script>
<script>
	import "@/scripts/cursorBlink";
	import "@/scripts/matchDeviceTheme";
	import "@/scripts/starsBackground";
</script>
