---
/**
 * Sidebar Component
 *
 * CSS checkbox-driven nav drawer.
 *
 * #nav-toggle checkbox (hidden) is the state machine.
 * body:has(#nav-toggle:checked) in sidebar.css handles panel/overlay/hamburger.
 * The hamburger label lives in Header.astro (for="nav-toggle").
 * JS handles: Escape key, scroll lock, close-on-click, header offset.
 */
import "@/styles/components/sidebar.css";
import { mainNavigation, navSections, sidebarOptions } from "@/data/navigation";
import { FLAVORS, FLAVOR_LABELS, FLAVOR_SWATCHES } from "@/scripts/flavorManager";
import asciiData from "@/data/ascii-art.json";
import AsciiWidget from "@/components/AsciiWidget.astro";
import AvatarMiniWidget from "@/components/AvatarMiniWidget.astro";

const currentPath = Astro.url.pathname;

// Most-specific match: find the longest nav href that matches the current path.
// This prevents /blog from staying active when navigating to /blog/some-post,
// if both /blog and /blog/some-post exist as nav items.
const activeHref = mainNavigation
	.map((l) => l.href)
	.filter((href) => (href === "/" ? currentPath === "/" : currentPath === href || currentPath.startsWith(href + "/")))
	.reduce((best, href) => (href.length > best.length ? href : best), "");

function isActive(linkHref: string): boolean {
	return linkHref === activeHref;
}

const grouped = navSections.map((s) => ({
	label: s.label,
	items: mainNavigation.filter((link) => link.section === s.key),
}));

type AsciiVariant = { text: string; font: string; art: string };
const eggVariantsJson = JSON.stringify((asciiData as AsciiVariant[]).filter((v) => v.text !== "404"));
---

<!-- State machine: hidden checkbox -->
<input type="checkbox" id="nav-toggle" class="nav-toggle-input" autocomplete="off" />

<!-- Nav panel -->
<aside
	role="navigation"
	aria-label="Main navigation"
	class="nav-menu fixed top-0 left-0 z-40 flex flex-col w-[var(--sidebar-width)] h-full -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out bg-base-100">
	<div class="nav-brand">
		<!-- Expanded: visitor-aware shell prompt -->
		<div class="nav-brand-expanded-content">
			<button
				type="button"
				class="nav-brand-prompt"
				id="nav-brand-terminal-trigger"
				data-navbrand-terminal-trigger
				data-navbrand-terminal-source="sidebar-expanded"
				data-navbrand-state="arrival"
				data-navbrand-effect="none"
				data-navbrand-tone="normal"
				aria-label="Open terminal">
				<span class="nav-brand-line">
					<span class="nav-brand-chrome">┌─[</span><span id="nav-brand-name" class="nav-brand-name">alex</span><span
						class="nav-brand-chrome">@</span
					><span class="nav-brand-host">alexmbugua.me</span><span class="nav-brand-chrome">]</span>
				</span>
				<span class="nav-brand-line">
					<span class="nav-brand-chrome">│ </span><span
						id="nav-brand-greeting"
						class="nav-brand-greeting"
						aria-live="polite">·</span
					>
				</span>
				<span class="nav-brand-line" id="nav-brand-sub-row">
					<span class="nav-brand-chrome">│ </span><span id="nav-brand-sub" class="nav-brand-sub" aria-hidden="true"
					></span>
				</span>
				<!-- Phase 3 teaser contract: this stays lightweight and only advertises
				terminal intent. `src/scripts/navBrand.ts` listens for interaction here
				and dispatches the shared `navbrand:open-terminal` event; the modal task
				owns the actual terminal window lifecycle. -->
				<span class="nav-brand-line nav-brand-teaser-line">
					<span class="nav-brand-chrome">│ </span><span id="nav-brand-teaser" class="nav-brand-teaser-text"
						>open terminal</span
					>
				</span>
				<span class="nav-brand-line">
					<span class="nav-brand-chrome">└─</span><span class="nav-brand-prompt-char">$</span><span
						class="nav-brand-chrome">
						~
					</span><span class="blink nav-brand-cursor" data-cursor-mode="active" aria-hidden="true">_</span>
				</span>
			</button>
		</div>
		<!-- Collapsed: avatar only (tab button outside handles expand) -->
		<div class="nav-brand-collapsed-content" aria-hidden="true">
			<div
				class="nav-brand-collapsed-trigger"
				role="button"
				tabindex="0"
				data-avatar-ready="false"
				data-navbrand-terminal-trigger
				data-navbrand-terminal-source="sidebar-collapsed"
				aria-label="Open terminal from collapsed sidebar">
				<AvatarMiniWidget instanceId="sidebar-header" canvasClass="nav-collapsed-header-avatar avatar-frame" />
				<span class="nav-brand-collapsed-prompt" aria-hidden="true">
					<span class="nav-brand-collapsed-prompt-glyph">&#x276F;</span>
					<span class="blink nav-brand-collapsed-prompt-cursor">&#95;</span>
				</span>
			</div>
		</div>
	</div>

	<nav class="nav-body" aria-label="Main navigation">
		{
			grouped.map(({ label, items }) =>
				items.length > 0 ? (
					<div class="nav-section" data-collapsed-hidden={items[0]?.section !== "main" ? "" : undefined}>
						<div class="nav-section-label">
							<span class="badge badge-secondary badge-sm">&#x276F;</span>
							<span class="nav-section-name">{label}</span>
						</div>
						<ul class="nav-list" role="list">
							{items.map((link) => {
								const active = isActive(link.href);
								return (
									<li>
										<b>
											<a
												class:list={["nav-link", { "nav-link--active": active }]}
												href={link.href}
												aria-label={link.ariaLabel}
												aria-current={active ? "page" : undefined}
												data-tooltip={link.name}
												{...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}>
												{link.multiPathIcon && link.pathCount ? (
													<span class={`${link.icon} nav-icon`} aria-hidden="true">
														{Array.from({ length: link.pathCount }, (_, i) => (
															<span class={`path${i + 1}`} />
														))}
													</span>
												) : (
													<i class={`${link.icon} nav-icon`} aria-hidden="true" />
												)}
												<span class="nav-text">{link.name}</span>
											</a>
										</b>
									</li>
								);
							})}
						</ul>
					</div>
				) : null
			)
		}

		<!-- Options section: user-controlled site preferences. Hidden in collapsed mode. -->
		{
			sidebarOptions.length > 0 && (
				<div class="nav-section" data-collapsed-hidden>
					<div class="nav-section-label">
						<span class="badge badge-secondary badge-sm">&#x276F;</span>
						<span class="nav-section-name">options</span>
					</div>
					<div class="nav-options-list">
						{sidebarOptions.map((option) => (
							<div class="nav-option">
								<div class="nav-option-control">
									<div class="nav-option-label-group">
										<i class={`${option.icon} nav-icon`} aria-hidden="true" />
										<label class="nav-option-label" for={option.id}>
											{option.label}
										</label>
										<sup
											class="nav-option-info-btn no-underline hover:bg-transparent text-info hover:text-info cursor-default"
											aria-label="More info"
											aria-describedby={`${option.id}-helper`}>
											<i class="icon-info-circle" aria-hidden="true" />
										</sup>
									</div>
									<input
										type="checkbox"
										id={option.id}
										class="toggle toggle-xs"
										aria-describedby={`${option.id}-helper`}
									/>
								</div>
								<p id={`${option.id}-helper`} class="nav-option-helper">
									{option.description}
								</p>
							</div>
						))}
					</div>
				</div>
			)
		}

		<!-- Flavor picker: optional color overlays on dark mode. Hidden in collapsed mode. -->
		<div class="nav-section" data-collapsed-hidden>
			<div class="nav-section-label">
				<span class="badge badge-secondary badge-sm">&#x276F;</span>
				<span class="nav-section-name">theme</span>
			</div>
			<div class="nav-flavor-picker" role="group" aria-label="Color flavor">
				{
					FLAVORS.map((flavor) => (
						<button
							type="button"
							class="nav-flavor-swatch"
							data-flavor-btn={flavor}
							aria-label={FLAVOR_LABELS[flavor]}
							aria-pressed="false"
							title={FLAVOR_LABELS[flavor]}
							style={FLAVOR_SWATCHES[flavor] ? `--swatch: ${FLAVOR_SWATCHES[flavor]}` : undefined}
						/>
					))
				}
			</div>
		</div>

		<!-- ASCII easter egg. visible on overscroll. Hidden in collapsed mode. -->
		<div class="nav-easter-egg" aria-hidden="true" data-collapsed-hidden>
			<AsciiWidget widgetId="nav-egg" variants={eggVariantsJson} artClass="nav-egg-art" />
		</div>
	</nav>

	<!-- Avatar footer: visible when expanded, hidden when collapsed -->
	<div class="nav-status">
		<AvatarMiniWidget instanceId="sidebar" canvasClass="nav-status-avatar avatar-frame" />
	</div>
</aside>

<!-- Overlay transparent click trap. closes nav -->
<label for="nav-toggle" class="nav-overlay" aria-hidden="true"></label>

<!-- Bookmark tab: fixed to the right edge of the sidebar. Desktop only. -->
<button
	id="sidebar-collapse-tab"
	type="button"
	class="nav-collapse-tab"
	aria-label="Collapse sidebar"
	aria-expanded="true">
	<i class="icon-sidebar-collapse nav-tab-icon nav-tab-icon--collapse" aria-hidden="true"></i>
	<i class="icon-sidebar-expand nav-tab-icon nav-tab-icon--expand" aria-hidden="true"></i>
</button>

<script>
	import "@/scripts/sidebarNav";
</script>
<script>
	import "@/scripts/sidebarCollapse";
</script>
<script>
	import "@/scripts/sidebarEgg";
</script>
<script>
	import "@/scripts/sidebarAvatar";
</script>
<script>
	import "@/scripts/cursorBlink";
	import "@/scripts/matchDeviceTheme";
	import "@/scripts/starsBackground";
	import "@/scripts/matrixBackground";
	import "@/scripts/flavorPicker";
</script>
<script>
	import "@/scripts/navBrand";
</script>
