---
import "@/styles/components/music-player-modal.css";
---

<div id="music-modal-root" data-pagefind-ignore transition:persist>
	<div id="music-modal-overlay" class="music-modal-overlay" hidden aria-hidden="true"></div>

	<button
		id="music-dock-chip"
		type="button"
		class="music-dock-chip"
		data-music-docked="false"
		data-dock-chip="music"
		hidden
		aria-label="Restore music player"
		title="Restore music player">
		<i class="icon-cassette" aria-hidden="true"></i>
		<span class="music-dock-chip__label">restore music</span>
	</button>

	<section
		id="music-terminal"
		class="music-terminal theme-scope"
		data-player-flavor="default"
		role="dialog"
		aria-label="Navidrome music player"
		tabindex="-1"
		hidden>
		<header id="music-terminal-drag-handle" class="music-terminal-topbar">
			<i class="music-window-icon text-xl icon-cassette" aria-hidden="true"></i>
			<p id="music-window-title" class="music-window-title">
				<span class="music-window-app">navidrome.exe</span><span class="music-window-separator" aria-hidden="true">
					|
				</span><span id="music-window-playlist" class="music-window-playlist">loading_playlist</span>
			</p>
			<div class="music-window-actions" aria-label="Player window controls">
				<button
					id="music-flavor-button"
					class="music-terminal-button music-theme-button"
					type="button"
					aria-label="Change music player theme flavor"
					title="Change music player theme flavor">
					&nbsp;DEFAULT&nbsp;
				</button>
				<button
					id="music-minimize-button"
					class="music-terminal-button collapse-button"
					type="button"
					aria-label="Minimize music player"
					title="Minimize music player">
					[_]
				</button>
				<button
					id="music-collapse-button"
					class="music-terminal-button collapse-button"
					type="button"
					aria-label="Collapse music player"
					title="Collapse music player"
					aria-expanded="true">
					[-]
				</button>
				<button
					id="music-close-button"
					class="music-terminal-button collapse-button"
					type="button"
					aria-label="Close music player"
					title="Close music player">
					[X]
				</button>
			</div>
		</header>

		<div class="music-terminal-body">
			<section class="music-visualizer-panel music-expanded" aria-label="Signal visualizer">
				<div class="music-signal-stack">
					<div class="music-now-file"
						><span class="music-now-prompt" aria-hidden="true">&gt;</span><span class="music-now-file-text"
							><span id="music-now-file">waiting_signal.mp3</span></span
						></div
					>
					<img id="music-cover" class="music-cover" src="/images/album-art.png" alt="" />
					<div
						id="music-signal-label"
						class="music-signal-label"
						data-text-effect="typing, decrypt, glitch-lock-on"
						data-text-effect-triggers="load, hover, focus, activate, tap, click, resume, route-enter, intersection, idle-return, content-change, manual, random-effect, random-time"
						data-text-effect-interval-ms="18000">[ carrier search... ]</div
					>
				</div>
				<div class="music-visualizer" aria-label="Audio visualizer">
					<div id="music-ascii-visualizer" class="music-ascii-visualizer" aria-hidden="true"></div>
				</div>
			</section>

			<section class="music-control-panel" aria-label="Playback controls">
				<div class="music-control-buttons">
					<button
						id="music-play-button"
						class="music-terminal-button music-primary-action"
						type="button"
						aria-label="Play music"
						title="Play music">&nbsp;[ <span class="music-play-label">PLAY</span> ]&nbsp;</button
					>
					<button
						id="music-stop-button"
						class="music-terminal-button"
						type="button"
						aria-label="Stop music"
						title="Stop music">&nbsp;[ STOP ]&nbsp;</button
					>
				</div>
				<label class="music-progress-wrap" aria-label="Track progress">
					<span class="sr-only">Track progress</span>
					<input id="music-progress" class="music-progress" type="range" min="0" max="100" value="0" step="0.1" />
					<span class="music-time-row" aria-live="off">
						<time id="music-time-elapsed" class="music-time" datetime="PT0S">00:00</time>
						<time id="music-time-duration" class="music-time" datetime="PT0S">00:00</time>
					</span>
				</label>
				<div class="music-secondary-controls" aria-label="Additional playback controls">
					<button
						id="music-shuffle-button"
						class="music-terminal-button music-icon-action"
						type="button"
						aria-label="Shuffle"
						title="Shuffle"
						aria-pressed="false">
						<i class="icon-shuffle" aria-hidden="true"></i>
					</button>
					<button
						id="music-previous-button"
						class="music-terminal-button music-icon-action"
						type="button"
						aria-label="Previous track"
						title="Previous track">
						<i class="icon-skip-backward" aria-hidden="true"></i>
					</button>
					<button
						id="music-next-button"
						class="music-terminal-button music-icon-action"
						type="button"
						aria-label="Next track"
						title="Next track">
						<i class="icon-skip-forward" aria-hidden="true"></i>
					</button>
					<button
						id="music-repeat-button"
						class="music-terminal-button music-icon-action"
						type="button"
						aria-label="Repeat"
						title="Repeat"
						aria-pressed="false">
						<i class="icon-repeat" aria-hidden="true"></i>
					</button>
				</div>
				<audio id="music-player" preload="none"> Your browser does not support the audio element. </audio>
			</section>

			<div class="music-expanded music-console-grid">
				<section class="music-panel" aria-labelledby="music-playlists-heading">
					<div class="music-panel-heading">
						<p id="music-playlists-heading" class="badge badge-primary">playlists</p>
						<span id="music-playlists-count" class="badge badge-accent">loading</span>
					</div>
					<div id="music-playlists-state" class="music-terminal-state">Loading public playlists...</div>
					<div id="music-playlists" class="music-terminal-list" hidden></div>
				</section>
			</div>
		</div>
		<button
			class="music-resize-handle music-resize-handle--n"
			type="button"
			data-music-resize="n"
			aria-label="Resize music player from top"
			title="Resize from top edge"
			tabindex="-1"></button>
		<button
			class="music-resize-handle music-resize-handle--e"
			type="button"
			data-music-resize="e"
			aria-label="Resize music player from right"
			title="Resize from right edge"
			tabindex="-1"></button>
		<button
			class="music-resize-handle music-resize-handle--s"
			type="button"
			data-music-resize="s"
			aria-label="Resize music player from bottom"
			title="Resize from bottom edge"
			tabindex="-1"></button>
		<button
			class="music-resize-handle music-resize-handle--w"
			type="button"
			data-music-resize="w"
			aria-label="Resize music player from left"
			title="Resize from left edge"
			tabindex="-1"></button>
		<button
			class="music-resize-handle music-resize-handle--ne"
			type="button"
			data-music-resize="ne"
			aria-label="Resize music player from top right"
			title="Resize from top right corner"
			tabindex="-1"></button>
		<button
			class="music-resize-handle music-resize-handle--nw"
			type="button"
			data-music-resize="nw"
			aria-label="Resize music player from top left"
			title="Resize from top left corner"
			tabindex="-1"></button>
		<button
			class="music-resize-handle music-resize-handle--se"
			type="button"
			data-music-resize="se"
			aria-label="Resize music player from bottom right"
			title="Resize from bottom right corner"
			tabindex="-1"></button>
		<button
			class="music-resize-handle music-resize-handle--sw"
			type="button"
			data-music-resize="sw"
			aria-label="Resize music player from bottom left"
			title="Resize from bottom left corner"
			tabindex="-1"></button>
	</section>
</div>

<script src="../scripts/musicPlayerModal.ts"></script>
