---

<!-- Share Notification -->
<div
	id={id}
	class="share-notification hidden"
	role="status"
	aria-live="polite"
	aria-atomic="true"
	data-title-options={JSON.stringify(titleOptions)}
	data-rare-title-options={JSON.stringify(rareTitleOptions)}>
	<span class="share-notification__sigil" aria-hidden="true">
		<i class="icon-rocket-takeoff"></i>
	</span>
	<span class="share-notification__copy">
		<strong class="share-notification__title font-retro" data-share-notification-title>{titleOptions[0]}</strong>
		<small class="share-notification__message" data-share-notification-message>{message}</small>
	</span>
	<button id={`${id}-close`} class="btn btn-frame btn-error btn-xs" aria-label="Close notification">
		<i class="icon-x-lg" aria-hidden="true"></i>
	</button>
</div>
