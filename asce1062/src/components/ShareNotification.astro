---
/**
 * Reusable share notification component
 * Shows a dismissible notification when content is copied to clipboard
 */
import "@/styles/components/share-notification.css";

interface Props {
	id: string;
	message?: string;
}

const { id, message = "Link copied!" } = Astro.props;

const titleOptions = [
