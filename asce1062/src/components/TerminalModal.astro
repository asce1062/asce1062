---
import "@/styles/components/terminal-modal.css";
---

<div id="terminal-modal-overlay" class="terminal-overlay" hidden aria-hidden="true"></div>

<button
	id="terminal-dock-chip"
	type="button"
	class="terminal-dock-chip"
	data-terminal-docked="false"
	hidden
	aria-label="Restore terminal"
	title="Restore terminal">
	<i class="icon-command-palette" aria-hidden="true"></i>
	<span class="terminal-dock-chip__label">restore signal</span>
</button>

<section
	id="terminal-modal"
	class="terminal-window"
	role="dialog"
	aria-labelledby="terminal-modal-title"
	aria-describedby="terminal-modal-status"
	tabindex="-1"
	hidden>
	<header id="terminal-modal-drag-handle" class="terminal-window__chrome">
		<div class="terminal-window__identity">
			<p class="terminal-window__eyebrow">Alex's Workstation</p>
			<h2 id="terminal-modal-title" class="terminal-window__title">stellar console</h2>
			<div class="terminal-window__presence" aria-live="polite">
				<p class="terminal-window__presence-line">
					<span id="terminal-modal-presence-badge" class="badge badge-warning badge-sm">last seen</span>
					<span id="terminal-modal-presence-text" class="terminal-window__presence-text">back the same day</span>
				</p>
				<p class="terminal-window__presence-line">
					<span class="badge badge-secondary badge-sm">visits</span>
					<span id="terminal-modal-presence-visits" class="terminal-window__presence-visits">1</span>
				</p>
				<p class="terminal-window__presence-line terminal-window__presence-line--atmosphere">
					<span class="badge badge-accent badge-sm">signal</span>
					<span
						id="terminal-modal-atmosphere"
						class="terminal-window__presence-text terminal-window__presence-text--atmosphere"
						data-text-effect="decrypt, typing, glitch-lock-on"
						data-text-effect-triggers="load, hover, activate, resume, route-enter, intersection, idle-return, random-effect, random-time"
						data-text-effect-interval-ms="18000">restoring context</span
					>
				</p>
			</div>
		</div>
		<div class="terminal-window__controls" aria-label="Terminal window controls">
			<button
				id="terminal-minimize"
				type="button"
				class="terminal-window__control btn btn-secondary btn-elevation btn-xs"
				data-terminal-control="minimize"
				aria-label="Minimize terminal"
				title="Minimize terminal">
				<span class="text-secondary-content" aria-hidden="true">_</span>
			</button>
			<button
				id="terminal-maximize"
				type="button"
				class="terminal-window__control btn btn-accent btn-pixel btn-xs"
				data-terminal-control="maximize"
				aria-label="Expand terminal"
				title="Expand terminal">
				<i id="terminal-maximize-icon" class="icon-square text-accent-content" aria-hidden="true"></i>
			</button>
			<button
				id="terminal-close"
				type="button"
				class="terminal-window__control btn btn-error btn-frame btn-xs"
				data-terminal-control="close"
				aria-label="Close terminal"
				title="Close terminal">
				<i class="icon-x-lg text-error-content" aria-hidden="true"></i>
			</button>
		</div>
	</header>

	<div class="terminal-window__statusbar">
		<span class="terminal-window__status terminal-window__status--signal">
			<i class="icon-command-palette" aria-hidden="true"></i>
			<span id="terminal-modal-status">incoming transmission</span>
		</span>
		<span id="terminal-modal-geometry" class="terminal-window__status terminal-window__status--geometry"
			>860&times;580</span
		>
	</div>

	<div class="terminal-window__body">
		<div id="terminal-modal-log" class="terminal-window__log" aria-live="polite"></div>
		<form id="terminal-modal-form" class="terminal-window__prompt-form" novalidate>
			<label class="terminal-window__prompt" for="terminal-modal-input">
				<span class="terminal-window__prompt-text">alex@alexmbugua.me //</span>
				<span class="terminal-window__input-shell">
					<span id="terminal-modal-mirror" class="terminal-window__mirror" data-empty="true" aria-hidden="true">
						<span id="terminal-modal-mirror-text" class="terminal-window__mirror-text"
							>search, explore, tune the signal</span
						>
						<span class="blink terminal-window__block-cursor" aria-hidden="true"></span>
					</span>
					<input
						id="terminal-modal-input"
						class="terminal-window__input"
						type="text"
						name="command"
						autocomplete="off"
						autocapitalize="none"
						autocorrect="off"
						spellcheck="false"
						enterkeyhint="go"
						placeholder="search, explore, tune the signal"
						aria-label="Run a terminal command"
					/>
				</span>
			</label>
		</form>
	</div>

	<button
		type="button"
		class="terminal-window__resize-handle terminal-window__resize-handle--n"
		data-terminal-resize="n"
		aria-label="Resize terminal from top edge"
		title="Resize from top edge"
		tabindex="-1"></button>
	<button
		type="button"
		class="terminal-window__resize-handle terminal-window__resize-handle--ne"
		data-terminal-resize="ne"
		aria-label="Resize terminal from top right corner"
		title="Resize from top right corner"
		tabindex="-1"></button>
	<button
		type="button"
		class="terminal-window__resize-handle terminal-window__resize-handle--nw"
		data-terminal-resize="nw"
		aria-label="Resize terminal from top left corner"
		title="Resize from top left corner"
		tabindex="-1"></button>
	<button
		type="button"
		class="terminal-window__resize-handle terminal-window__resize-handle--e"
		data-terminal-resize="e"
		aria-label="Resize terminal from right edge"
		title="Resize from right edge"
		tabindex="-1"></button>
	<button
		type="button"
		class="terminal-window__resize-handle terminal-window__resize-handle--s"
		data-terminal-resize="s"
		aria-label="Resize terminal from bottom edge"
		title="Resize from bottom edge"
		tabindex="-1"></button>
	<button
		type="button"
		class="terminal-window__resize-handle terminal-window__resize-handle--se"
		data-terminal-resize="se"
		aria-label="Resize terminal from bottom right corner"
		title="Resize from bottom right corner"
		tabindex="-1"></button>
	<button
		type="button"
		class="terminal-window__resize-handle terminal-window__resize-handle--sw"
		data-terminal-resize="sw"
		aria-label="Resize terminal from bottom left corner"
		title="Resize from bottom left corner"
		tabindex="-1"></button>
	<button
		type="button"
		class="terminal-window__resize-handle terminal-window__resize-handle--w"
		data-terminal-resize="w"
		aria-label="Resize terminal from left edge"
		title="Resize from left edge"
		tabindex="-1"></button>
</section>

<script>
	import { initTerminalShortcut } from "@/scripts/keyboardShortcuts";
	import "@/scripts/terminalModal";

	let terminalShortcutCleanup: (() => void) | null = null;

	function bindTerminalShortcut() {
		terminalShortcutCleanup?.();
		terminalShortcutCleanup = initTerminalShortcut();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", bindTerminalShortcut, { once: true });
	} else {
		bindTerminalShortcut();
	}

	document.addEventListener("astro:page-load", bindTerminalShortcut);
</script>
