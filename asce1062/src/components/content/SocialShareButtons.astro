---
/**
 * Provides sharing functionality for blog posts across multiple platforms
 */
import ShareNotification from "@/components/ShareNotification.astro";

interface Props {
	title: string;
	url: string;
}

const { title, url } = Astro.props;
const shareText = `${title}\n${url}`;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
const encodedShareText = encodeURIComponent(shareText);

const shareLinks = [
	{
		platform: "WhatsApp",
		url: `https://wa.me/?text=${encodedTitle} ${encodedUrl}`,
		icon: "icon-whatsapp",
		label: "Share on WhatsApp",
	},
	{
		platform: "Facebook",
		url: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
		icon: "icon-facebook",
		label: "Share on Facebook",
	},
	{
		platform: "LinkedIn",
		url: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
		icon: "icon-linkedin",
		label: "Share on LinkedIn",
	},
	{
		platform: "Reddit",
		url: `https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`,
		icon: "icon-reddit",
		label: "Share on Reddit",
	},
	{
		platform: "X/Twitter",
		url: `https://x.com/intent/post?text=${encodedTitle}&url=${encodedUrl}`,
		icon: "icon-twitter-x",
		label: "Share on X/Twitter",
	},
	{
		platform: "Telegram",
		url: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`,
		icon: "icon-telegram",
		label: "Share on Telegram",
	},
	{
		platform: "Mastodon",
		url: `https://share.joinmastodon.org/#text=${encodedShareText}`,
		icon: "icon-mastodon",
		label: "Share on Mastodon",
	},
	{
		platform: "Bluesky",
		url: `https://bsky.app/intent/compose?text=${encodedShareText}`,
		icon: "icon-bluesky",
		label: "Share on Bluesky",
	},
	{
		platform: "Pinterest",
		url: `https://pinterest.com/pin/create/button/?url=${encodedUrl}&description=${encodedTitle}`,
		icon: "icon-pinterest",
		label: "Share on Pinterest",
	},
	{
		platform: "Email",
		url: `mailto:?subject=${encodedTitle}&body=${encodedUrl}`,
		icon: "icon-envelope-at",
		label: "Share via Email",
	},
];
---

<div class="flex flex-col flex-wrap items-center justify-center gap-4 text-center">
	<b class="italic">Share this post on:</b>
	<div class="flex flex-wrap items-center justify-center gap-1">
		{
			shareLinks.map(({ url, icon, label }) => (
				<a
					href={url}
					target={label.includes("Email") ? undefined : "_blank"}
					rel={label.includes("Email") ? undefined : "noopener noreferrer"}
					class="no-underline group scale-90 p-2 hover:rotate-6 sm:p-1"
					aria-label={label}>
					<i class={`${icon} text-2xl`} />
				</a>
			))
		}
		<a
			id="blog-share-btn"
			data-url={url}
			data-title={title}
			class="no-underline group scale-90 p-2 hover:-rotate-6 sm:p-1 cursor-pointer"
			aria-label="Share or copy link">
			<i class="icon-share text-2xl"></i>
		</a>
	</div>
</div>

<ShareNotification id="blog-share-notification" />

<script>
	import { initShareNotification, shareOrCopyToClipboard } from "@/scripts/feedbackManager";

	function setupBlogShare() {
		const copyLinkBtn = document.getElementById("blog-share-btn");
		if (!copyLinkBtn) return;

		// Initialize share notification
		initShareNotification("blog-share-notification");

		// Remove old event listener if it exists
		copyLinkBtn.replaceWith(copyLinkBtn.cloneNode(true));
		const newCopyLinkBtn = document.getElementById("blog-share-btn");

		newCopyLinkBtn?.addEventListener("click", async () => {
			const url = newCopyLinkBtn.getAttribute("data-url");
			const title = newCopyLinkBtn.getAttribute("data-title");
			if (url && title) {
				const shareText = `${title}\n${url}`;
				await shareOrCopyToClipboard({
					shareData: {
						title,
						text: title,
						url,
					},
					clipboardText: shareText,
					notificationId: "blog-share-notification",
				});
			}
		});
	}

	// Initialize on first load
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", setupBlogShare);
	} else {
		setupBlogShare();
	}

	// Reinitialize after view transitions
	document.addEventListener("astro:page-load", setupBlogShare);
</script>
