<button
	id="theme-toggle-btn"
	class="float-right h-11 w-11 rounded-md transition-all duration-100 hover:text-accent hover:rotate-6 cursor-pointer flex items-center justify-center"
	aria-label="Switch page theme">
	<i id="toggleIcon"></i>
</button>

<script>
	import { initThemeSwitcher, handleThemeToggle, setupThemeShortcut } from "@/scripts/themeManager";

	let _themeAc: AbortController | null = null;

	function setup(): void {
		// Abort the previous navigation's listeners before re-registering.
		// AbortController handles both the button click and the keyboard shortcut,
		// so neither can accumulate across Astro soft navigations.
		_themeAc?.abort();
		_themeAc = new AbortController();
		const { signal } = _themeAc;

		initThemeSwitcher();

		const btn = document.getElementById("theme-toggle-btn");
		if (btn) {
			btn.addEventListener("click", handleThemeToggle, { signal });
		}

		setupThemeShortcut(signal);
	}

	// astro:page-load fires on initial hard load and after every soft navigation.
	// This single listener is sufficient. no DOMContentLoaded guard needed.
	document.addEventListener("astro:page-load", setup);
</script>
