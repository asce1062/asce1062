# GitHub Personal Access Token for fetching repositories
# Create a token at: https://github.com/settings/tokens
# Required scopes: public_repo (or repo for private repos)
GITHUB_PAT=your_github_personal_access_token_here

# Astro DB Remote URL (Turso libSQL)
# Get from: turso db show <db-name> --url
ASTRO_DB_REMOTE_URL=libsql://your-database.turso.io

# Astro DB App Token (Turso auth token)
# Get from: turso db tokens create <db-name>
ASTRO_DB_APP_TOKEN=your_turso_auth_token_here

# Commit Hash
# In production: automatically set by Netlify as COMMIT_REF
# For local dev: run `git rev-parse HEAD` to get your current commit
COMMIT_REF=your_commit_hash_here

# ---------------------------------------------------------------------------
# Guestbook Moderation Configuration
# ---------------------------------------------------------------------------

# Secret salt for hashing visitor IP and User-Agent before storage.
# Generate with: node -e "console.log(crypto.randomUUID())"
# If unset, a default salt is used (fine for dev, set a real one in production).
GUESTBOOK_HASH_SALT=your_random_salt_here

# Shared secret token for accessing the admin moderation page at /admin/guestbook.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
ADMIN_TOKEN=your_admin_token_here

# ---------------------------------------------------------------------------
# Email Notifications (Resend)
# ---------------------------------------------------------------------------

# Resend API key for sending guestbook notification emails.
# See: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Verified sender address for notification emails.
# Must be a verified domain/sender in your Resend dashboard.
# See: https://resend.com/docs/dashboard/domains/introduction
GUESTBOOK_FROM_EMAIL=Guestbook <guestbook@alexmbugua.me>

# (Optional) Override recipient email for guestbook notifications.
# Defaults to SOCIAL.email from src/config/site-config.ts if not set.
# GUESTBOOK_NOTIFY_TO=you@example.com

# (Optional) Dedicated reply-to address for copy emails sent to guests.
# Keeps the reply address stable even if GUESTBOOK_NOTIFY_TO changes.
# Falls back to GUESTBOOK_NOTIFY_TO (or SOCIAL.email) if not set.
# GUESTBOOK_REPLY_TO=alex@alexmbugua.me

# (Optional) Per-attempt fetch timeout for Resend API calls, in milliseconds.
# Minimum 1000. Defaults to 10000 (10 s).
# GUESTBOOK_EMAIL_TIMEOUT_MS=10000

# (Optional) Maximum number of retries for 429 / 5xx Resend API errors.
# Capped at 5. Defaults to 2.
# GUESTBOOK_EMAIL_RETRIES=2
