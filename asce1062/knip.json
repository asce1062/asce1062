{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignoreDependencies": [
    "pagefind",
    "lightningcss",
    "@netlify/plugin-sitemap",
    "@netlify/plugin-lighthouse",
    "vite-plugin-pwa",
    "autoprefixer",
    "postcss-nesting",
    "drizzle-orm",
    "vitest"
  ],
  "ignore": ["public/css/**", "public/fonts/**", "public/**/demo-files/**"],

  "entry": [
    "astro.config.*",
    "vitest.config.*",
    "markdown.config.ts",
    "src/pages/**/*.{astro,mdx}",
    "src/layouts/**/*.astro",
    "src/components/**/*.astro",
    "src/scripts/**/*.{ts,js}",
    "scripts/**/*.{ts,js,mjs}",
    "db/**/*.{ts,js}",
    "src/**/*.test.{ts,js}",
    "src/**/*.spec.{ts,js}"
  ],

  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true,
    "function": true
  },

  "ignoreIssues": {
    "src/lib/email/templates/**/*.astro": ["types"],
    "src/lib/email/helpers/**": ["exports"]
  }
}
